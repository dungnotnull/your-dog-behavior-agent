# Dog Behavior Agent — Environment Variables
# Copy this file to .env and fill in your actual values

# ── LLM API Keys ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Model Selection (optional overrides) ──────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# ── Privacy Mode ──────────────────────────────────────────────────────────────
# Set to "true" to force Ollama (no data leaves the machine)
PRIVACY_MODE=false

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Optional: set HF_TOKEN for access to gated models
HF_TOKEN=

# ── Agent Settings ────────────────────────────────────────────────────────────
DATA_DIR=./data
MODELS_DIR=./models
HOST=0.0.0.0
PORT=8009
LOG_LEVEL=info

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set false to skip wav2vec2 (faster, CPU-only mode)
USE_WAV2VEC2=true
# Set false to disable MediaPipe visual analysis
USE_VISUAL_ANALYSIS=true
